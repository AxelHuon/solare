---
import { buttonVariants } from "@/components/ui/button"

interface Props {
  eyebrow?: string | null
  headline?: string | null
  headlineAccent?: string | null
  subheadline?: string | null
  primaryCtaLabel?: string | null
  primaryCtaHref?: string | null
  secondaryCtaLabel?: string | null
  secondaryCtaHref?: string | null
}

const {
  eyebrow = "Cours particuliers en ligne",
  headline = "Apprenez le piano",
  headlineAccent = "à votre rythme.",
  subheadline = "Réservez un cours avec un professeur diplômé, où que vous soyez. Du tout premier accord aux nocturnes de Chopin — on avance ensemble, à votre tempo.",
  primaryCtaLabel = "Réserver un cours",
  primaryCtaHref = "#book",
  secondaryCtaLabel = "Voir les professeurs",
  secondaryCtaHref = "#teachers",
} = Astro.props
---

<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__grain" aria-hidden="true"></div>

  <svg
    class="hero__staff hero__staff--top"
    viewBox="0 0 1440 60"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <line x1="0" y1="8" x2="1440" y2="8" />
    <line x1="0" y1="20" x2="1440" y2="20" />
    <line x1="0" y1="32" x2="1440" y2="32" />
    <line x1="0" y1="44" x2="1440" y2="44" />
    <line x1="0" y1="56" x2="1440" y2="56" />
  </svg>

  <div class="hero__inner">
    {eyebrow && (
      <div class="hero__eyebrow">
        <svg viewBox="0 0 16 16" aria-hidden="true" class="hero__note">
          <path
            d="M10.5 1.5v7.3a2.8 2.8 0 1 1-1.2-2.3V3.1l-4.8 1.1v5.9a2.8 2.8 0 1 1-1.2-2.3V3.5l7.2-1.7v-.3Z"
            fill="currentColor"
          ></path>
        </svg>
        <span>{eyebrow}</span>
      </div>
    )}

    <h1 class="hero__title">
      <span class="hero__title-roman">{headline}</span>
      {headlineAccent && (
        <>
          {" "}
          <em class="hero__title-accent">{headlineAccent}</em>
        </>
      )}
    </h1>

    {subheadline && <p class="hero__sub">{subheadline}</p>}

    <div class="hero__ctas">
      {primaryCtaLabel && (
        <a
          href={primaryCtaHref ?? "#"}
          class={buttonVariants({ size: "lg" }) + " hero__cta-primary"}
        >
          {primaryCtaLabel}
        </a>
      )}
      {secondaryCtaLabel && (
        <a
          href={secondaryCtaHref ?? "#"}
          class={buttonVariants({ variant: "ghost", size: "lg" }) + " hero__cta-ghost"}
        >
          {secondaryCtaLabel}
          <svg viewBox="0 0 16 16" aria-hidden="true" class="hero__cta-arrow">
            <path d="M3 8h9m0 0L8 4m4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
    </div>

    <div class="hero__proof">
      <div class="hero__stars" aria-hidden="true">
        <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
      </div>
      <span class="hero__proof-text">
        <strong>4,9/5</strong> · plus de 1 200 élèves en France
      </span>
    </div>
  </div>

  <div class="hero__keys" aria-hidden="true">
    <svg
      class="hero__keys-svg"
      viewBox="0 0 1400 120"
      preserveAspectRatio="none"
    >
      <defs>
        <linearGradient id="heroWhiteKey" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="oklch(0.99 0.005 85)" />
          <stop offset="100%" stop-color="oklch(0.93 0.012 80)" />
        </linearGradient>
        <linearGradient id="heroBlackKey" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="oklch(0.2 0.015 40)" />
          <stop offset="100%" stop-color="oklch(0.08 0.01 40)" />
        </linearGradient>
      </defs>

      {Array.from({ length: 20 }).map((_, i) => {
        const w = 70
        const x = i * w
        return (
          <rect
            x={x}
            y={0}
            width={w}
            height={120}
            fill="url(#heroWhiteKey)"
            stroke="oklch(0.78 0.02 65 / 0.7)"
            stroke-width="1"
            rx="2"
          />
        )
      })}

      {Array.from({ length: 20 }).map((_, i) => {
        const posInOctave = i % 7
        const hasBlack = [0, 1, 3, 4, 5].includes(posInOctave)
        if (!hasBlack) return null
        const w = 70
        const blackW = 36
        const x = (i + 1) * w - blackW / 2
        return (
          <rect
            x={x}
            y={0}
            width={blackW}
            height={74}
            fill="url(#heroBlackKey)"
            rx="2"
          />
        )
      })}
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: 100svh;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.25rem, 4vw, 3rem) 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(120% 80% at 50% 0%, oklch(0.99 0.02 85) 0%, transparent 60%),
      linear-gradient(180deg, oklch(0.975 0.015 82) 0%, oklch(0.965 0.02 78) 100%);
    color: oklch(0.22 0.02 45);
    font-family: var(--font-sans);
  }

  .hero__glow {
    position: absolute;
    inset: -20% -20% auto -20%;
    height: 90%;
    background:
      radial-gradient(45% 60% at 22% 30%, oklch(0.89 0.15 75 / 0.55), transparent 70%),
      radial-gradient(40% 55% at 78% 20%, oklch(0.85 0.18 55 / 0.4), transparent 70%);
    filter: blur(30px);
    z-index: -1;
    pointer-events: none;
  }

  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.25;
    mix-blend-mode: multiply;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.32  0 0 0 0 0.22  0 0 0 0 0.12  0 0 0 0.35 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }

  .hero__staff {
    position: absolute;
    left: 0;
    right: 0;
    width: 100%;
    height: 60px;
    pointer-events: none;
    z-index: -1;
  }
  .hero__staff--top {
    top: clamp(6rem, 14vh, 10rem);
    opacity: 0.12;
  }
  .hero__staff line {
    stroke: oklch(0.35 0.05 55);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .hero__inner {
    position: relative;
    max-width: 54rem;
    text-align: center;
    padding: clamp(3rem, 10vh, 6rem) 0 clamp(8rem, 14vh, 10rem);
    animation: heroFade 1.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem 0.375rem 0.625rem;
    border-radius: 999px;
    background: oklch(0.98 0.015 85);
    border: 1px solid oklch(0.88 0.04 75 / 0.7);
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.6) inset,
      0 1px 2px oklch(0.3 0.02 40 / 0.06);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: oklch(0.35 0.06 55);
    margin-bottom: 2rem;
    animation: heroRise 0.9s 0.05s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__note {
    width: 14px;
    height: 14px;
    color: oklch(0.62 0.18 65);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.75rem, 7.2vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
    margin: 0;
    color: oklch(0.2 0.02 45);
    animation: heroRise 1s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__title-roman {
    font-style: normal;
  }
  .hero__title-accent {
    font-style: italic;
    color: oklch(0.45 0.14 55);
    position: relative;
  }
  .hero__title-accent::after {
    content: "";
    position: absolute;
    left: 0.05em;
    right: 0.05em;
    bottom: 0.02em;
    height: 0.45em;
    background: oklch(0.88 0.18 82 / 0.45);
    z-index: -1;
    border-radius: 2px;
    transform: skewX(-6deg);
  }

  .hero__sub {
    margin: 1.75rem auto 0;
    max-width: 36rem;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.1vw + 0.6rem, 1.1875rem);
    line-height: 1.55;
    color: oklch(0.38 0.02 50);
    animation: heroRise 1s 0.18s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero__ctas {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    justify-content: center;
    animation: heroRise 1s 0.25s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__cta-primary {
    padding-inline: 1.75rem !important;
    height: 3rem !important;
    font-size: 0.9375rem !important;
    background: oklch(0.22 0.02 45) !important;
    color: oklch(0.98 0.015 85) !important;
    border-radius: 999px !important;
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.08) inset,
      0 8px 24px -8px oklch(0.22 0.02 45 / 0.5);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .hero__cta-primary:hover {
    background: oklch(0.28 0.04 50) !important;
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.1) inset,
      0 12px 32px -8px oklch(0.22 0.02 45 / 0.55);
  }
  .hero__cta-ghost {
    padding-inline: 1rem !important;
    height: 3rem !important;
    font-size: 0.9375rem !important;
    color: oklch(0.25 0.02 45) !important;
    background: transparent !important;
  }
  .hero__cta-ghost:hover {
    background: oklch(0.95 0.03 80) !important;
  }
  .hero__cta-arrow {
    width: 16px;
    height: 16px;
    margin-left: 0.25rem;
    transition: transform 0.25s ease;
  }
  .hero__cta-ghost:hover .hero__cta-arrow {
    transform: translateX(3px);
  }

  .hero__proof {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: oklch(0.42 0.02 45);
    animation: heroRise 1s 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__stars {
    display: inline-flex;
    gap: 1px;
    color: oklch(0.72 0.16 75);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }
  .hero__proof-text strong {
    font-weight: 600;
    color: oklch(0.25 0.02 45);
  }

  .hero__keys {
    position: absolute;
    left: -6%;
    right: -6%;
    bottom: 0;
    height: clamp(80px, 12vh, 130px);
    pointer-events: none;
    perspective: 900px;
    animation: heroKeys 1.2s 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
    filter: drop-shadow(0 -8px 24px oklch(0.3 0.03 50 / 0.18));
  }
  .hero__keys-svg {
    width: 100%;
    height: 100%;
    display: block;
    transform: rotateX(38deg) translateY(20%) scale(1.1);
    transform-origin: bottom center;
    mask-image: linear-gradient(180deg, transparent 0%, black 30%, black 100%);
  }

  @keyframes heroFade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes heroRise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes heroKeys {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__inner, .hero__eyebrow, .hero__title, .hero__sub, .hero__ctas, .hero__proof, .hero__keys {
      animation: none !important;
    }
  }
</style>
